// Test: nested compile-time conditions
const A = 1;
const B = 2;
fn main() {
    v = vec![];
    if A == 1 {
        if B == 2 {
            v.push(100);  // OK: both conditions are compile-time true
        } else {
            v.push(200);
        }
    } else {
        v.push(300);
    }
    assert v[0] == 100;
    return;
}
