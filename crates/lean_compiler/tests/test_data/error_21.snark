// Error: push to outer-scope vector with runtime condition (not compile-time evaluable)
const ARR = [0, 1, 2];
fn main() {
    v = vec![1, 2, 3];
    x = 5;  // runtime value
    if x == 5 {
        v.push(4);  // Error: condition involves runtime variable, cannot be evaluated at compile time
    }
    return;
}
